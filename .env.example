# Neon Database URL
# Get from https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@ep-example-123456-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Neon Auth URL
# Get from Neon Console → Auth → Settings
NEXT_PUBLIC_NEON_AUTH_URL=https://ep-example-123456.neonauth.us-east-1.aws.neon.tech/neondb/auth

# WebSocket URL (optional — for real-time collaboration)
# Leave empty to disable collaboration features
NEXT_PUBLIC_WS_URL=
